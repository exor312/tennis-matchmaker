  "prd": {
    "version": "1.0",
    "app_name": "Tennis Matchmaker",
    "purpose": "Automate tennis matchmaking during open play sessions. Players check in, system auto-pairs them based on selected mode (random, skill-based, round-robin), tracks game-level scores, and produces a daily summary with win/loss records.",
    "target_user": "Tennis club organizers and casual open-play groups",
    "pages": [
      { "route": "/", "name": "Check-in", "auth_required": false, "description": "Player enters name, selects format, joins the active session" },
      { "route": "/setup", "name": "Session Setup", "auth_required": false, "description": "Configure matchmaking mode, format, session type" },
      { "route": "/score", "name": "Score Entry", "auth_required": false, "description": "View active matches, enter scores" },
      { "route": "/summary", "name": "Daily Summary", "auth_required": false, "description": "End-of-day leaderboard, match results, W/L records" }
    ],
    "features": [
      { "id": "F001", "name": "Player Check-in", "description": "Enter name, self-rate skill, join pool", "pages_involved": ["/"] },
      { "id": "F002", "name": "Matchmaking Modes", "description": "Random, skill-based, round-robin", "pages_involved": ["/setup", "/"] },
      { "id": "F003", "name": "Format Support", "description": "Singles, Doubles, Mix", "pages_involved": ["/setup", "/"] },
      { "id": "F004", "name": "Game-level Scoring", "description": "Track per-game scores within a match", "pages_involved": ["/score"] },
      { "id": "F005", "name": "Daily Summary", "description": "Results + leaderboard + W/L records", "pages_involved": ["/summary"] },
      { "id": "F006", "name": "Session Types", "description": "Drop-in or scheduled block", "pages_involved": ["/setup"] }
    ],
    "auth": { "required": false, "strategy": "none", "providers": [] },
    "entities": [
      { "name": "sessions", "fields": ["id uuid", "name text", "mode text", "format text", "session_type text", "doubles_team_policy text", "starts_at timestamptz", "ends_at timestamptz", "created_at timestamptz"] },
      { "name": "players", "fields": ["id uuid", "name text", "skill_level integer", "session_id uuid", "created_at timestamptz"] },
      { "name": "matches", "fields": ["id uuid", "session_id uuid", "player1_id uuid", "player2_id uuid", "player3_id uuid", "player4_id uuid", "format text", "status text", "created_at timestamptz"] },
      { "name": "match_scores", "fields": ["id uuid", "match_id uuid", "set_number integer", "player1_games integer", "player2_games integer", "tiebreak_score text", "created_at timestamptz"] },
      { "name": "match_results", "fields": ["id uuid", "match_id uuid", "winner_ids uuid[]", "loser_ids uuid[]", "sets_won_player1 integer", "sets_won_player2 integer", "created_at timestamptz"] }
    ],
    "realtime_needed": false,
    "realtime_features": [],
    "external_integrations": [],
    "open_questions": [],
    "decisions": [
      { "id": "D001", "question": "Skill level method", "decision": "Self-rated at check-in (1-5 scale)" },
      { "id": "D002", "question": "Doubles team assignment", "decision": "Configurable per session: fixed-for-session OR re-match-each-round" }
    ]
  },
