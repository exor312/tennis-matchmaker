  "prd": {
    "version": "1.0",
    "app_name": "Tennis Matchmaker",
    "purpose": "Automate tennis matchmaking during open play sessions. Players check in, system auto-pairs them based on selected mode (random, skill-based, round-robin), tracks game-level scores, and produces a daily summary with win/loss records.",
    "target_user": "Tennis club organizers and casual open-play groups",
    "pages": [
      {
        "route": "/",
        "name": "Check-in",
        "auth_required": false,
        "description": "Player enters name, selects format, joins the active session"
      },
      {
        "route": "/setup",
        "name": "Session Setup",
        "auth_required": false,
        "description": "Configure matchmaking mode, format, session type"
      },
      {
        "route": "/score",
        "name": "Score Entry",
        "auth_required": false,
        "description": "View active matches, enter scores"
      },
      {
        "route": "/summary",
        "name": "Daily Summary",
