    ],
    "db_schema": [
      { "table": "sessions", "columns": ["id uuid PK", "name text NOT NULL", "mode text NOT NULL", "format text NOT NULL", "session_type text NOT NULL", "doubles_team_policy text DEFAULT 'fixed'", "starts_at timestamptz", "ends_at timestamptz", "created_at timestamptz DEFAULT now()"], "rls": false, "realtime": false, "indexes": ["created_at"] },
      { "table": "players", "columns": ["id uuid PK", "name text NOT NULL", "skill_level integer NOT NULL DEFAULT 3", "session_id uuid FK→sessions.id", "created_at timestamptz DEFAULT now()"], "rls": false, "realtime": false, "indexes": ["session_id"] },
      { "table": "matches", "columns": ["id uuid PK", "session_id uuid FK→sessions.id", "player1_id uuid FK→players.id", "player2_id uuid FK→players.id", "player3_id uuid FK→players.id", "player4_id uuid FK→players.id", "format text NOT NULL", "status text DEFAULT 'pending'", "created_at timestamptz DEFAULT now()"], "rls": false, "realtime": false, "indexes": ["session_id", "status"] },
      { "table": "match_scores", "columns": ["id uuid PK", "match_id uuid FK→matches.id", "set_number integer NOT NULL", "player1_games integer NOT NULL DEFAULT 0", "player2_games integer NOT NULL DEFAULT 0", "tiebreak_score text", "created_at timestamptz DEFAULT now()"], "rls": false, "realtime": false, "indexes": ["match_id"] },
      { "table": "match_results", "columns": ["id uuid PK", "match_id uuid FK→matches.id", "winner_ids uuid[]", "loser_ids uuid[]", "sets_won_player1 integer", "sets_won_player2 integer", "created_at timestamptz DEFAULT now()"], "rls": false, "realtime": false, "indexes": ["match_id"] }
    ],
    "type_contracts": {
      "Session": "{ id: string; name: string; mode: 'random' | 'skill' | 'round-robin'; format: 'singles' | 'doubles' | 'mix'; session_type: 'drop-in' | 'scheduled'; doubles_team_policy: 'fixed' | 'rematch'; starts_at: string | null; ends_at: string | null; created_at: string }",
      "Player": "{ id: string; name: string; skill_level: number; session_id: string; created_at: string }",
      "Match": "{ id: string; session_id: string; player1_id: string; player2_id: string; player3_id: string | null; player4_id: string | null; format: 'singles' | 'doubles' | 'mix'; status: 'pending' | 'in_progress' | 'completed'; created_at: string }",
      "MatchScore": "{ id: string; match_id: string; set_number: number; player1_games: number; player2_games: number; tiebreak_score: string | null; created_at: string }",
      "MatchResult": "{ id: string; match_id: string; winner_ids: string[]; loser_ids: string[]; sets_won_player1: number; sets_won_player2: number; created_at: string }"
    }
  },
